{
  "name": "py-style",
  "displayName": "Py-Style: Raymond Hettinger Principles",
  "description": "Python code style linter and guide based on Raymond Hettinger's principles for beautiful, pythonic code.",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Python"
  ],
  "keywords": [
    "python",
    "linter",
    "style",
    "hettinger",
    "pythonic",
    "code quality"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onCommand:py-style.analyze",
    "onCommand:py-style.fix",
    "onSave"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "py-style.analyze",
        "title": "Py-Style: Analyze Current File",
        "shortTitle": "Analyze",
        "description": "Analyze current Python file for py-style violations"
      },
      {
        "command": "py-style.fix",
        "title": "Py-Style: Fix Safe Issues",
        "shortTitle": "Fix",
        "description": "Automatically fix safe py-style issues in current file"
      },
      {
        "command": "py-style.analyzeWorkspace",
        "title": "Py-Style: Analyze Workspace",
        "shortTitle": "Analyze All",
        "description": "Analyze all Python files in workspace"
      },
      {
        "command": "py-style.toggle",
        "title": "Py-Style: Toggle",
        "shortTitle": "Toggle",
        "description": "Toggle py-style analysis on file save"
      }
    ],
    "configuration": {
      "title": "Py-Style",
      "properties": {
        "py-style.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable py-style analysis"
        },
        "py-style.runOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run py-style analysis on file save"
        },
        "py-style.autoFix": {
          "type": "boolean",
          "default": false,
          "description": "Automatically fix safe issues on save"
        },
        "py-style.severity": {
          "type": "string",
          "default": "style",
          "enum": ["error", "warning", "info", "style"],
          "description": "Severity level for py-style diagnostics"
        },
        "py-style.include": {
          "type": "array",
          "default": ["**/*.py"],
          "items": {
            "type": "string"
          },
          "description": "File patterns to include (glob patterns)"
        },
        "py-style.exclude": {
          "type": "array",
          "default": ["**/tests/**", "**/venv/**", "**/.venv/**"],
          "items": {
            "type": "string"
          },
          "description": "File patterns to exclude (glob patterns)"
        }
      }
    },
    "languages": [
      {
        "id": "python",
        "aliases": ["Python", "python"],
        "extensions": [".py", ".pyi", ".pyw", ".pyx", ".pyd"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "python",
        "scopeName": "source.python",
        "path": "./syntaxes/python.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.0",
    "vscode-languageserver-textdocument": "^1.0.8"
  },
  "publisher": "your-publisher-name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-repo/py-style-vscode"
  },
  "bugs": {
    "url": "https://github.com/your-repo/py-style-vscode/issues"
  },
  "homepage": "https://github.com/your-repo/py-style-vscode",
  "icon": "icons/py-style-icon.png",
  "badges": [
    {
      "description": "Python 3.10+",
      "url": "https://img.shields.io/badge/python-3.10+-blue.svg"
    },
    {
      "description": "Raymond Hettinger Approved",
      "url": "https://img.shields.io/badge/style-Hettinger-orange.svg"
    }
  ]
}
